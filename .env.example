# OpenAI (voice + phrasing)
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=onyx

# Roboflow (QC vision) — from your project's Versions page, e.g. my-car-qc/3
ROBOFLOW_API_KEY=your-roboflow-key
ROBOFLOW_MODEL_ID=your-project/1
ROBOFLOW_URL=https://serverless.roboflow.com

# QC thresholds (tune after testing)
QC_PRESENCE_THRESHOLD=0.55
QC_LOW_THRESHOLD=0.35

PORT=3000
